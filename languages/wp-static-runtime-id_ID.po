# ── General / Dashboard ───────────────────────────────────────────────────────

msgid "Folder free/ not found."
msgstr "Folder free/ tidak ditemukan."

msgid "Core classes not found. Make sure the free/ folder is intact."
msgstr "Class inti tidak ditemukan. Pastikan folder free/ tidak rusak."

msgid "Premium features require an active license."
msgstr "Fitur premium memerlukan lisensi aktif."

msgid "Activate License"
msgstr "Aktifkan Lisensi"

msgid "New content published. Cache for related pages has been cleared automatically."
msgstr "Konten baru telah dipublikasi. Cache halaman terkait telah dihapus otomatis."

msgid "To rebuild the cache with the latest content, follow these steps:"
msgstr "Untuk membangun ulang cache dengan konten terbaru, ikuti langkah berikut:"

msgid "1. Flush All Cache"
msgstr "1. Hapus Semua Cache"

msgid "2. Start Crawler"
msgstr "2. Jalankan Crawler"

msgid "or"
msgstr "atau"

msgid "Upgrade to Premium"
msgstr "Upgrade ke Premium"

msgid "for automatic ISR with zero downtime"
msgstr "untuk ISR otomatis tanpa downtime"

# ── Settings ──────────────────────────────────────────────────────────────────

msgid "Settings saved."
msgstr "Pengaturan disimpan."

msgid "WP Static Runtime — Settings"
msgstr "WP Static Runtime — Pengaturan"

msgid "General"
msgstr "Umum"

msgid "Enable Cache"
msgstr "Aktifkan Cache"

msgid "Serve static HTML to visitors"
msgstr "Sajikan HTML statis kepada pengunjung"

msgid "Cache TTL"
msgstr "TTL Cache"

msgid "Seconds (0 = never expire)"
msgstr "Detik (0 = tidak pernah kadaluarsa)"

msgid "Skip Logged-In Users"
msgstr "Lewati Pengguna yang Login"

msgid "Recommended: logged-in users always see dynamic content"
msgstr "Disarankan: pengguna yang login selalu melihat konten dinamis"

msgid "Skip Query Strings"
msgstr "Lewati Query String"

msgid "Don't cache URLs with query parameters"
msgstr "Jangan cache URL dengan parameter query"

msgid "Optimisation"
msgstr "Optimasi"

msgid "Gzip Cache Files"
msgstr "Kompresi Cache Gzip"

msgid "Store a gzip-compressed version alongside plain HTML"
msgstr "Simpan versi terkompresi gzip di samping HTML biasa"

msgid "Minify HTML"
msgstr "Minify HTML"

msgid "Remove whitespace and HTML comments from cached pages"
msgstr "Hapus spasi dan komentar HTML dari halaman yang di-cache"

msgid "Apache Rewrite Rules"
msgstr "Aturan Rewrite Apache"

msgid "Auto-write .htaccess rules to serve static files without PHP"
msgstr "Tulis otomatis aturan .htaccess untuk menyajikan file statis tanpa PHP"

msgid "WooCommerce Hybrid Mode"
msgstr "Mode Hybrid WooCommerce"

msgid "Enable Hybrid Cache"
msgstr "Aktifkan Cache Hybrid"

msgid "Cache shop, products, categories. Skip cart/checkout."
msgstr "Cache toko, produk, kategori. Lewati keranjang/checkout."

msgid "Excluded WooCommerce Pages"
msgstr "Halaman WooCommerce yang Dikecualikan"

msgid "One slug per line. e.g. cart, checkout, my-account"
msgstr "Satu slug per baris. contoh: cart, checkout, my-account"

msgid "Exclusions"
msgstr "Pengecualian"

msgid "Excluded URLs"
msgstr "URL yang Dikecualikan"

msgid "One URL path per line. e.g. /members, /private"
msgstr "Satu path URL per baris. contoh: /members, /private"

msgid "Excluded Cookies"
msgstr "Cookie yang Dikecualikan"

msgid "Skip caching if these cookie names are present."
msgstr "Lewati cache jika nama cookie ini ada."

msgid "Save Settings"
msgstr "Simpan Pengaturan"

msgid "Apache — .htaccess Rules"
msgstr "Apache — Aturan .htaccess"

msgid "These rules let Apache serve cached HTML directly — without invoking PHP at all (5–15ms TTFB)."
msgstr "Aturan ini memungkinkan Apache menyajikan HTML yang di-cache secara langsung tanpa memanggil PHP sama sekali (5–15ms TTFB)."

msgid ".htaccess path"
msgstr "Path .htaccess"

msgid "file not found"
msgstr "file tidak ditemukan"

msgid "not writable (chmod)"
msgstr "tidak bisa ditulis (chmod)"

msgid "exists & writable"
msgstr "ada & bisa ditulis"

msgid "Generated Rules"
msgstr "Aturan yang Dibuat"

msgid "Rules are written automatically to .htaccess when \"Apache Rewrite Rules\" is enabled above. You can also copy-paste manually."
msgstr "Aturan ditulis otomatis ke .htaccess saat \"Aturan Rewrite Apache\" aktif di atas. Anda juga bisa copy-paste secara manual."

msgid "Copy and paste into your .htaccess manually, placing it before the # BEGIN WordPress block."
msgstr "Copy dan paste ke .htaccess Anda secara manual, letakkan sebelum blok # BEGIN WordPress."

msgid "Nginx — Server Block Snippet"
msgstr "Nginx — Cuplikan Server Block"

msgid "Nginx cannot be configured by PHP directly. Add the following snippet inside your"
msgstr "Nginx tidak bisa dikonfigurasi oleh PHP secara langsung. Tambahkan cuplikan berikut ke dalam"

msgid "block in your Nginx config file, BEFORE the existing WordPress block."
msgstr "blok di file konfigurasi Nginx Anda, SEBELUM blok WordPress yang ada."

msgid "How to use:"
msgstr "Cara penggunaan:"

msgid "Open your Nginx config file (e.g."
msgstr "Buka file konfigurasi Nginx Anda (misal:"

msgid "Copy the snippet below into the"
msgstr "Copy cuplikan di bawah ke dalam"

msgid "block, before the"
msgstr "blok, sebelum baris"

msgid "line"
msgstr ""

msgid "Run"
msgstr "Jalankan"

msgid "to verify, then"
msgstr "untuk verifikasi, lalu"

msgid "Adjust the PHP-FPM socket path in the fastcgi_pass line if it differs from the default."
msgstr "Sesuaikan path socket PHP-FPM di baris fastcgi_pass jika berbeda dari default."

# ── Crawler Page ──────────────────────────────────────────────────────────────

msgid "Manual Mode — Free Version"
msgstr "Mode Manual — Versi Gratis"

msgid "The crawler must be run manually each time new content is published. Auto-Crawler (scheduled cron + ISR) is available in Premium."
msgstr "Crawler harus dijalankan manual setiap kali ada konten baru dipublikasi. Auto-Crawler (cron terjadwal + ISR) tersedia di Premium."

msgid "Visits all public URLs and builds a static HTML cache. No external sitemap required."
msgstr "Mengunjungi semua URL publik dan membangun cache HTML statis. Tidak memerlukan sitemap eksternal."

msgid "Server Connectivity"
msgstr "Konektivitas Server"

msgid "URLs to Cache"
msgstr "URL yang akan Di-cache"

msgid "Cache Directory"
msgstr "Direktori Cache"

msgid "Crawl Controls"
msgstr "Kontrol Crawl"

msgid "Last Crawl Results"
msgstr "Hasil Crawl Terakhir"

# ── Diagnostic ────────────────────────────────────────────────────────────────

msgid "Diagnostic"
msgstr "Diagnostik"

msgid "This page checks every part of WP Static Runtime to find what's not working."
msgstr "Halaman ini memeriksa setiap bagian WP Static Runtime untuk menemukan apa yang tidak berfungsi."

msgid "Check"
msgstr "Pemeriksaan"

msgid "Value / Status"
msgstr "Nilai / Status"

msgid "Fix"
msgstr "Perbaikan"

msgid "Manual Cache Test"
msgstr "Tes Cache Manual"

msgid "Click the button below to manually cache the homepage. Check your cache directory afterwards."
msgstr "Klik tombol di bawah untuk meng-cache halaman utama secara manual. Periksa direktori cache Anda setelahnya."

msgid "Test: Cache Homepage Now"
msgstr "Tes: Cache Halaman Utama Sekarang"

msgid "Reinstall advanced-cache.php"
msgstr "Instal Ulang advanced-cache.php"

msgid "Cache Directory"
msgstr "Direktori Cache"

msgid "No cached files found yet."
msgstr "Belum ada file yang di-cache."

msgid "HTML files found:"
msgstr "File HTML ditemukan:"

msgid "Directory:"
msgstr "Direktori:"

# ── Premium / License ─────────────────────────────────────────────────────────

msgid "Premium Feature — License Required"
msgstr "Fitur Premium — Lisensi Diperlukan"

msgid "Activate your license key to use this feature."
msgstr "Aktifkan license key Anda untuk menggunakan fitur ini."

msgid "Buy Premium"
msgstr "Beli Premium"

msgid "License Activation"
msgstr "Aktivasi Lisensi"

msgid "License Status"
msgstr "Status Lisensi"

msgid "WordPress URL where the WP Static Runtime License Server plugin is installed."
msgstr "URL WordPress tempat plugin WP Static Runtime License Server diinstall."

msgid "Enter the license key you received after purchase."
msgstr "Masukkan license key yang Anda terima setelah pembelian."

msgid "Deactivate if you want to transfer the license to another domain."
msgstr "Nonaktifkan jika ingin memindahkan lisensi ke domain lain."

msgid "Premium features require an active license."
msgstr "Fitur premium memerlukan lisensi aktif."

msgid "Recommendation: Enable System Cron"
msgstr "Rekomendasi: Aktifkan System Cron"

msgid "ISR relies on WP-Cron to process the background queue. WordPress's built-in WP-Cron only runs when a request hits your site — on low traffic this can delay processing by minutes or hours."
msgstr "ISR bergantung pada WP-Cron untuk memproses antrian background. WP-Cron bawaan WordPress hanya berjalan saat ada request — di traffic rendah bisa delay menit hingga jam."

msgid "For responsive ISR, disable the built-in WP-Cron and use a system cron job."
msgstr "Untuk ISR yang responsif, nonaktifkan WP-Cron bawaan dan gunakan system cron."

msgid "Add to wp-config.php:"
msgstr "Tambahkan ke wp-config.php:"

msgid "Add to server crontab"
msgstr "Tambahkan ke crontab server"

msgid "Option A — via curl (most common):"
msgstr "Pilihan A — via curl (paling umum):"

msgid "Option B — via WP-CLI (lighter):"
msgstr "Pilihan B — via WP-CLI (lebih ringan):"

msgid "With a system cron running every minute, ISR will process the queue within seconds of content changing."
msgstr "Dengan system cron setiap menit, ISR akan memproses antrian dalam hitungan detik setelah konten berubah."

msgid "Premium settings saved."
msgstr "Pengaturan premium disimpan."

msgid "Activating..."
msgstr "Mengaktifkan..."

msgid "Are you sure you want to deactivate the license on this site?"
msgstr "Yakin ingin menonaktifkan lisensi di website ini?"

msgid "Enable Auto-Crawler"
msgstr "Aktifkan Auto-Crawler"

msgid "Pre-build cache from sitemap hourly (WP-Cron)"
msgstr "Bangun cache dari sitemap setiap jam (WP-Cron)"

msgid "Crawler runs automatically every hour to keep all page caches up to date."
msgstr "Crawler berjalan otomatis setiap jam untuk memperbarui cache semua halaman."

